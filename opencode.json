{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read":  "allow",
    "edit": "allow",
    "bash": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
   
  },

  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "enabled": true
    }
  }
}
